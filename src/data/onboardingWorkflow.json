  "forms": [
    {
      "id": "form-employee-info",
      "title": "Employee Profile Information",
      "description": "Standard registration form for personal details and role designation.",
      "questions": [
        {
          "id": "q-fullname",
          "type": "text",
          "label": "Full Name",
          "required": true,
          "displayNumber": "1"
        },
        {
          "id": "q-department",
          "type": "dropdown",
          "label": "Department Name",
          "options": [
            "Engineering",
            "Finance",
            "Operations",
            "Marketing"
          ],
          "required": true,
          "displayNumber": "2"
        },
        {
          "id": "q-role",
          "type": "dropdown",
          "label": "Job Title / Role",
          "options": [
            "Software Engineer",
            "Financial Analyst",
            "Operations Associate",
            "Marketing Specialist"
          ],
          "required": true,
          "displayNumber": "3"
        },
        {
          "id": "q-remote",
          "type": "dropdown",
          "label": "Will this employee work remotely?",
          "options": [
            "Yes",
            "No"
          ],
          "required": true,
          "displayNumber": "4"
        }
      ]
    },
    {
      "id": "form-remote-agreement",
      "title": "Remote Work & Hardware Shipping",
      "description": "Information required to ship office equipment and sign home-office agreements.",
      "questions": [
        {
          "id": "q-shipping-address",
          "type": "textarea",
          "label": "Home Delivery Address",
          "required": true,
          "displayNumber": "1"
        },
        {
          "id": "q-shipping-phone",
          "type": "text",
          "label": "Contact Phone Number",
          "required": true,
          "displayNumber": "2"
        },
        {
          "id": "q-desk-needed",
          "type": "dropdown",
          "label": "Do you need an ergonomic desk and chair shipped?",
          "options": [
            "Yes, full desk & chair bundle",
            "No, I have my own setup"
          ],
          "required": true,
          "displayNumber": "3"
        }
      ]
    },
    {
      "id": "form-dev-setup",
      "title": "Developer Machine & Tooling Preferences",
      "description": "Configuration inputs for building developer laptops and setting permissions.",
      "questions": [
        {
          "id": "q-dev-laptop",
          "type": "dropdown",
          "label": "Developer Hardware Option",
          "options": [
            "MacBook Pro 16\" (M3 Max, 64GB RAM)",
            "ThinkPad P16 (Intel i9, 64GB RAM, Linux)"
          ],
          "required": true,
          "displayNumber": "1"
        },
        {
          "id": "q-github-handle",
          "type": "text",
          "label": "GitHub Username",
          "required": true,
          "displayNumber": "2"
        },
        {
          "id": "q-aws-access",
          "type": "dropdown",
          "label": "Do you require AWS sandbox access?",
          "options": [
            "Yes, Full Admin Sandbox",
            "No, Read-Only Console"
          ],
          "required": true,
          "displayNumber": "3"
        }
      ]
    },
    {
      "id": "form-financial-check",
      "title": "Financial Integrity Compliance",
      "description": "Mandatory background disclosure for members of the financial audit department.",
      "questions": [
        {
          "id": "q-compliance-check",
          "type": "dropdown",
          "label": "Have you completed the NDA and conflict of interest disclosures?",
          "options": [
            "Yes, fully signed",
            "No, pending signature"
          ],
          "required": true,
          "displayNumber": "1"
        },
        {
          "id": "q-previous-firm",
          "type": "text",
          "label": "Please disclose any financial firms worked at in the last 12 months",
          "required": true,
          "displayNumber": "2"
        }
      ]
    },
    {
      "id": "form-office-badge",
      "title": "Office Desk & Security Access Card",
      "description": "For hybrid/on-premise workers. Security photo and desk assignment details.",
      "questions": [
        {
          "id": "q-office-location",
          "type": "dropdown",
          "label": "Assigned Office Base",
          "options": [
            "New York HQ - Floor 4",
            "London Office - Floor 1",
            "Tokyo Hub - Floor 6"
          ],
          "required": true,
          "displayNumber": "1"
        },
        {
          "id": "q-badge-photo",
          "type": "dropdown",
          "label": "Have you uploaded a high-resolution ID photo for your access card?",
          "options": [
            "Yes, uploaded to portal",
            "No, scheduled on first day"
          ],
          "required": true,
          "displayNumber": "2"
        }
      ]
    }
